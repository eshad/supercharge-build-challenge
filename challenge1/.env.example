# ── Required ──────────────────────────────────────────────────────────────
# Telegram Bot Token — get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Public HTTPS URL of your deployed bot (Railway.app URL)
WEBHOOK_URL=https://your-app.railway.app

# OpenAI API Key — get from platform.openai.com
OPENAI_API_KEY=sk-...

# ── Google Sheets Lead Capture ────────────────────────────────────────────
# Google Sheet ID (from the URL: docs.google.com/spreadsheets/d/THIS_PART/edit)
GOOGLE_SHEET_ID=your_google_sheet_id

# Google Service Account credentials (JSON string — paste the full JSON content)
GOOGLE_CREDS_JSON={"type":"service_account","project_id":"..."}

# ── Escalation Alerts ─────────────────────────────────────────────────────
# Slack Incoming Webhook URL (from your Slack app settings)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# Email escalation recipient
ESCALATION_EMAIL=support@supercharge.sg

# SMTP settings (for email escalation)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
